{
  "name": "vanta-omni-link",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.vantacorp.omnilink",
    "productName": "System Service Update",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "linux": {
      "target": "deb",
      "category": "Utility"
    }
  },
  "dependencies": {
    "axios": "^1.7.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}