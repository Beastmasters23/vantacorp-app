import { createClientFromRequest } from 'npm:@base44/sdk@0.8.31';

/**
 * vantaExpandHive — Vanta calls this (or an admin triggers it) to generate
 * a personalized curl-and-run install command for a new node to join the hive.
 *
 * Vanta can call this autonomously when:
 *   - An admin says "add this machine to the hive"
 *   - Vanta discovers a new reachable node
 *   - A new admin wants to join
 */

Deno.serve(async (req) => {
  const base44 = createClientFromRequest(req);
  try {
    const user = await base44.auth.me();
    if (!user) return Response.json({ error: 'Unauthorized' }, { status: 401 });

    const body = await req.json().catch(() => ({}));
    const { target_hostname, note } = body;

    // Correctly get APP_ID from environment for constructing the URL
    const appId = Deno.env.get('BASE44_APP_ID') || 'UNKNOWN_APP_ID';

    // Validate and construct appUrl reliably
    let appUrl = (Deno.env.get('VANTA_APP_URL') || '').replace(/\\/$/, '');
    if (!appUrl || appUrl.startsWith('ghp_')) {
      console.warn(`[vantaExpandHive] VANTA_APP_URL env variable is misconfigured ('${appUrl}'). Forcing to standard Base44 URL.`);
      appUrl = `https://app.base44.com/api/apps/${appId}`;
    }
    const funcBase = `${appUrl}/functions`;

    const deploySecret = Deno.env.get('VANTA_DEPLOY_SECRET') || '';

    // Generate a short-lived HMAC-signed token (1 hour TTL)
    const payload = {
      hostname: target_hostname || 'any',
      exp: Date.now() + 60 * 60 * 1000, // 1 hour TTL
    };
    const payloadStr = JSON.stringify(payload);
    const encoder = new TextEncoder();
    const cryptoKey = await crypto.subtle.importKey(
      'raw', encoder.encode(deploySecret),
      { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']
    );
    const sigBuffer = await crypto.subtle.sign('HMAC', cryptoKey, encoder.encode(payloadStr));
    const sigHex = Array.from(new Uint8Array(sigBuffer)).map(b => b.toString(16).padStart(2, '0')).join('');
    const token = `${btoa(payloadStr)}.${sigHex}`;

    const deployUrl = `${funcBase}/vantaDeployShell?token=${encodeURIComponent(token)}`;

    // Log this expansion event
    await base44.asServiceRole.entities.VantaHealingLog.create({
      trigger: `Hive expansion initiated by ${user.full_name || user.email}${target_hostname ? ` — target: ${target_hostname}` : ''}`,
      language: 'system',
      issues_found: [],
      summary: `Admin ${user.full_name || user.email} generated a hive install command${target_hostname ? ` for node "${target_hostname}"` : ''}.${note ? ' Note: ' + note : ''}`,
      status: 'Clean',
      pr_created: false,
    });

    // Notify via vantaSpeak (fire-and-forget — don't let failures block the response)
    const curlCommand = `VANTA_HOSTNAME="${target_hostname || 'any'}" bash <(curl -sSL "${deployUrl}")`; // Define curlCommand before vantaSpeak

    base44.asServiceRole.functions.invoke('vantaSpeak', {
      message: `🐝 **Hive Expansion Initiated**\\n\\nAdmin **${user.full_name || user.email}** has generated a node installer${target_hostname ? ` for \\\`${target_hostname}\\\`` : ''}.\\n\\nOnce the script runs, the new node will boot, pull my guardrails, and join the hive automatically. I'll absorb it into the brain network on first heartbeat.\\n\\n\`\`\`\\n${curlCommand}\\n\`\`\``,
      broadcast: true,
    }).catch(e => console.warn('[vantaExpandHive] speak warn:', e.message));

    console.log(`[vantaExpandHive] Expansion command generated by ${user.email} for ${target_hostname || 'any node'}`);

    return Response.json({
      status: 'ok',
      curl_command: curlCommand,
      deploy_url: deployUrl,
      target_hostname: target_hostname || null,
      message: `Run the curl command on the target Linux machine to join the hive. Guardrails are embedded automatically.`,
    });

  } catch (error) {
    console.error('[vantaExpandHive] Error:', error.message);
    return Response.json({ error: error.message }, { status: 500 });
  }
});